rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.matches('^.+@.+\\..+$') &&
             data.role in ['speaking', 'deaf'];
    }

    function isValidCall(data) {
      return data.keys().hasAll(['participants', 'startTime', 'mode']) &&
             data.participants is list &&
             data.startTime is string &&
             data.mode in ['video', 'live'];
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Call history
    match /calls/{callId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.participants) && isValidCall(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants) && isValidCall(request.resource.data);
    }
  }
}
